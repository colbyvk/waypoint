# Python venv + caches
.venv/
__pycache__/
*.pyc
.mypy_cache/
.ruff_cache/

# Run outputs — created on first scan, regenerated every run. The suppression
# store + allowlist are tracked (they are memory); these dirs are not committed.
reports/
beacons/

# Generated beacon-schema docs — derived from infra/ + tag_map.yaml by
# detectors/gen_schema_infra.py, so they never drift. Reproduced on demand; only
# the hand-written README (the shared schema) is tracked.
schema-infra/*
!schema-infra/README.md

# Toolchain build dirs
node_modules/
target/

# CodeQL bundle — a ~1.3 GB vendored toolchain installed by detectors/install_codeql.sh.
# Never commit it; re-install with that script.
.codeql/

# Generated per-rule precision cache. The suppression STORE + allowlist are tracked
# (they are the team's memory); this one is derived from verdicts and machine-local.
suppression/calibration.json

.DS_Store
.pytest_cache/
