{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "CodeQL",
          "rules": [
            {
              "id": "py/sql-injection",
              "name": "py/sql-injection",
              "shortDescription": { "text": "SQL query built from user-controlled sources" },
              "properties": {
                "security-severity": "8.8",
                "tags": ["security", "external/cwe/cwe-089"]
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "py/sql-injection",
          "ruleIndex": 0,
          "level": "error",
          "message": { "text": "This SQL query depends on a user-provided value." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "repo/db/queries.py" },
                "region": { "startLine": 42 }
              }
            }
          ],
          "codeFlows": [
            {
              "threadFlows": [
                {
                  "locations": [
                    { "location": {
                        "physicalLocation": { "artifactLocation": { "uri": "repo/routes/api.py" }, "region": { "startLine": 10 } },
                        "message": { "text": "request.json['q'] (user input)" } } },
                    { "location": {
                        "physicalLocation": { "artifactLocation": { "uri": "repo/services/search.py" }, "region": { "startLine": 5 } },
                        "message": { "text": "passed through run_search(term)" } } },
                    { "location": {
                        "physicalLocation": { "artifactLocation": { "uri": "repo/db/queries.py" }, "region": { "startLine": 42 } },
                        "message": { "text": "reaches db.execute(...)" } } }
                  ]
                }
              ]
            }
          ],
          "properties": { "security-severity": "8.8" }
        }
      ]
    }
  ]
}
